{
  "info": {
    "_postman_id": "8d6986fc-d1d2-4980-ad1e-00915966295f",
    "name": "Resmapi",
    "description": "This collection validates the main user-management flows of the Resmapi API. It includes setup and teardown requests, along with test scenarios for creating users, updating user data, changing passwords, deleting users, searching users by name, and validating login behavior.\n\nThe requests cover both positive and negative cases, such as valid operations, missing or blank fields, duplicate email or login values, invalid IDs, invalid credentials, and empty or populated search results. Overall, this collection is designed to support functional validation of the API’s user endpoints and their error handling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "49832651",
    "_collection_link": "https://go.postman.co/collection/49832651-8d6986fc-d1d2-4980-ad1e-00915966295f?source=collection_link"
  },
